# Duneborn Secure Server Configuration
PORT=5000

# OPTION A: Full-stack E-Mail Configuration (For Express server.js deployment)
# Fill these in to send live email dispatches to bhanu@duneborn.dev via SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# OPTION B: Purely Static E-Mail Configuration (For Cloudflare Pages / Static Hosting dist uploads)
# Go to https://web3forms.com/ and request a free Access Key for bhanu@duneborn.dev.
# Paste the key here so that static HTML/JS can send emails securely without exposing credentials!
VITE_WEB3FORMS_KEY=
